package main

import (
	_ "embed"
	"flag"
	"log"

	"{{.ModulePath}}/models"
	"{{.SDKModule}}/db"
	"{{.SDKModule}}/runtime"
)

//go:embed service.yaml
var configYAML []byte

func main() {
	mode := flag.String("mode", "entry", "run mode: entry (HTTP) or exit (workers)")
	flag.Parse()

	svc, err := runtime.NewFromYAML(configYAML)
	if err != nil {
		log.Fatalf("init: %v", err)
	}

{{- if .HasDB}}
	pool := svc.PoolPG("pg-main")
	table, err := db.NewTable[models.{{.ModelName}}](pool, "{{.DBTable}}")
	if err != nil {
		log.Fatalf("table: %v", err)
	}
	svc.WithCRUD("{{.ModelName}}", runtime.NewCRUDProvider(table, &models.{{.ModelName}}Hooks{}))
	svc.WithHooks("{{.ModelName}}", &models.{{.ModelName}}Hooks{})
{{- end}}
{{- range .ExitWorkers}}
	svc.WithExit("{{.Handler}}", {{.Handler}})
{{- end}}
{{- range .CronJobs}}
	svc.WithCron("{{.Handler}}", {{.Handler}})
{{- end}}

	switch *mode {
	case "entry":
		log.Printf("starting {{.ServiceName}} entry on :%d", {{.Port}})
	case "exit":
		log.Printf("starting {{.ServiceName}} exit workers")
	}

	if err := svc.Run(); err != nil {
		log.Fatalf("run: %v", err)
	}
}
