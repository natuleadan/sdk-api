name: {{.ServiceName}}
port: {{.Port}}

{{- if .HasDB}}
databases:
  - name: {{.DBName}}
    driver: postgres
    url: "${DATABASE_URL}"
    pool:
      max_conns: 10
      min_conns: 2
{{- end}}
{{- if .HasNATS}}

nats:
  - name: primary
    url: "${NATS_URL}"
    streams:
{{- range .StreamNames}}
      - name: {{.}}
{{- end}}
{{- end}}

entry:
{{- if .HasDB}}
  - type: crud
    model: {{.ModelName}}
    db: {{.DBName}}
    table: {{.DBTable}}
    resource: {{.ResourceName}}
    path: /{{.ResourceName}}
{{- end}}
{{- if .HasRest}}
{{- range .RestEndpoints}}
  - type: rest
    method: {{.Method}}
    path: {{.Path}}
    handler: {{.HandlerName}}
{{- end}}
{{- end}}
{{- if .HasNATS}}
{{- range .Consumers}}

exit:
  - name: {{.Durable}}
    subscribe:
      stream: {{.Stream}}
      subject: {{.Stream}}
    handler: {{.Handler}}
    max_concurrent: 10
    reply: false
{{- end}}
{{- end}}

server:
  host: "0.0.0.0"
  api_prefix: /api
  middleware:
    - path: "/api/*"
      apply:
        - logger
        - breaker
        - cors
